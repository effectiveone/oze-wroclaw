---
const year = new Date().getFullYear();
---
<footer style="background:var(--text);color:#eee;padding:2.5rem 0 1.5rem;margin-top:4rem;">
  <div class="container">
    <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:2rem;margin-bottom:1.5rem;">
      <div>
        <h3 style="font-family:'Nunito',sans-serif;color:var(--yellow);margin-bottom:0.75rem;">OZE Wrocław</h3>
        <p style="font-size:0.9rem;color:#aaa;line-height:1.6;">Energetyczny portal Dolnego Śląska. Fotowoltaika, pompy ciepła, czysta energia dla Wrocławia i regionu.</p>
      </div>
      <div>
        <h4 style="font-family:'Nunito',sans-serif;color:var(--yellow);font-size:0.8rem;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:0.5rem;">Serwis</h4>
        <a href="/" style="display:block;color:#aaa;font-size:0.9rem;margin-bottom:0.4rem;">Strona główna</a>
        <a href="/blog" style="display:block;color:#aaa;font-size:0.9rem;">Artykuły</a>
      </div>
      <div>
        <h4 style="font-family:'Nunito',sans-serif;color:var(--yellow);font-size:0.8rem;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:0.5rem;">Polecamy</h4>
        <a href="https://ecoaudyt.app" target="_blank" style="display:block;color:var(--yellow);font-size:0.9rem;font-weight:600;">→ ecoaudyt.app</a>
      </div>
    </div>
    <div style="border-top:1px solid #444;padding-top:1rem;text-align:center;">
      <p style="font-size:0.8rem;color:#666;">© {year} OZE Wrocław</p>
    </div>
  </div>
</footer>
