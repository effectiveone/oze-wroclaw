---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="Artykuły — OZE Wrocław">
  <div class="container" style="padding:2.5rem 1.5rem 3rem;">
    <div style="margin-bottom:2rem;">
      <h1 style="font-family:'Nunito',sans-serif;font-size:2.2rem;font-weight:900;color:var(--orange);">Artykuły</h1>
      <p style="color:var(--text-muted);">{posts.length} materiałów o energii odnawialnej</p>
    </div>
    {posts.length > 0 ? (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">
        {posts.map(p => <PostCard title={p.data.title} description={p.data.description} slug={p.slug} pubDate={p.data.pubDate} tags={p.data.tags} />)}
      </div>
    ) : <p style="color:var(--text-muted);text-align:center;padding:4rem 0;">Artykuły pojawią się wkrótce.</p>}
  </div>
</Layout>
