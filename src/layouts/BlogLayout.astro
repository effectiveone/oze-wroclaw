---
import Layout from './Layout.astro';
const { frontmatter } = Astro.props;
const dateStr = new Date(frontmatter.pubDate).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Layout title={frontmatter.title} description={frontmatter.description}>
  <div class="container" style="padding:2rem 1.5rem 4rem;">
    <header style="background:linear-gradient(135deg,var(--orange),var(--orange-dark));color:#fff;padding:2.5rem;border-radius:12px;margin-bottom:2rem;">
      {frontmatter.tags?.map(t => <span style="background:rgba(255,255,255,0.2);color:#fff;font-size:0.7rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:20px;margin-right:0.4rem;text-transform:uppercase;">{t}</span>)}
      <h1 style="font-family:'Nunito',sans-serif;font-size:clamp(1.7rem,4vw,2.8rem);font-weight:800;margin:0.75rem 0 0.5rem;color:#fff;">{frontmatter.title}</h1>
      <p style="font-size:0.9rem;opacity:0.85;margin-bottom:0.5rem;">{dateStr} · {frontmatter.author}</p>
      <p style="font-size:1.05rem;opacity:0.9;">{frontmatter.description}</p>
    </header>
    <div style="max-width:760px;" class="article-prose"><slot /></div>
  </div>
</Layout>
<style>
.article-prose :global(h2) { font-family:'Nunito',sans-serif;font-weight:800;color:var(--orange);font-size:1.5rem;margin:2rem 0 0.75rem;border-left:4px solid var(--yellow);padding-left:0.75rem; }
.article-prose :global(h3) { font-family:'Nunito',sans-serif;font-weight:700;color:var(--text);font-size:1.2rem;margin:1.5rem 0 0.5rem; }
.article-prose :global(p) { margin-bottom:1.25rem;line-height:1.8; }
.article-prose :global(a) { color:var(--orange);font-weight:600; }
</style>
